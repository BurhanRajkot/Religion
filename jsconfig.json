{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["Religion/src/*"]
    },
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom"],
    "target": "esnext",
    "checkJs": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": []
  },
  "include": ["Religion/src/components/**/*.js", "Religion/src/pages/**/*.jsx", "Religion/src/Layout.jsx"],
  "exclude": ["node_modules"]
}
